# Copy to .env and fill in your backend URL.
#
# iOS Simulator (same machine):
#   EXPO_PUBLIC_API_URL=http://127.0.0.1:8000
#
# Physical device on the same WiFi:
#   EXPO_PUBLIC_API_URL=http://192.168.1.XX:8000
#
# Hosted (Modal / Railway / Fly.io):
#   EXPO_PUBLIC_API_URL=https://your-app.modal.run

EXPO_PUBLIC_API_URL=http://127.0.0.1:8000
